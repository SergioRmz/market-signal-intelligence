{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/bmv-signal-intelligence/contracts/events/asset-event.schema.json",
  "title": "AssetEvent",
  "description": "Base event contract for educational/technical market intelligence events.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "occurred_at",
    "source",
    "asset",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "category"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": ["allowed", "conditional", "prohibited"]
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "url": {
          "type": "string"
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol", "market"],
      "properties": {
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "market": {
          "type": "string",
          "minLength": 1
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        }
      }
    },
    "payload": {
      "type": "object"
    }
  }
}
