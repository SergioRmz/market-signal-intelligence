{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bmv-signal-intelligence.local/specs/003/normalized-market-snapshot.schema.json",
  "title": "Normalized Market Snapshot",
  "description": "Planning contract for canonical watchlist-aligned local market snapshot samples.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "normalized_snapshot_id",
    "schema_version",
    "raw_snapshot_id",
    "asset",
    "observed_at",
    "normalized_at",
    "observed_values",
    "provenance"
  ],
  "properties": {
    "normalized_snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "raw_snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "asset": {
      "$ref": "#/$defs/normalizedAsset"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "normalized_at": {
      "type": "string",
      "format": "date-time"
    },
    "observed_values": {
      "$ref": "#/$defs/observedValues"
    },
    "provenance": {
      "$ref": "#/$defs/normalizationProvenance"
    }
  },
  "$defs": {
    "normalizedAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol", "market", "asset_role"],
      "properties": {
        "symbol": {
          "type": "string",
          "pattern": "^[A-Z0-9]+$"
        },
        "market": {
          "type": "string",
          "minLength": 1
        },
        "asset_role": {
          "type": "string",
          "enum": ["monitoring_target", "reference_benchmark"]
        }
      }
    },
    "observedValues": {
      "type": "object",
      "additionalProperties": true,
      "required": ["last_price", "currency", "volume"],
      "properties": {
        "last_price": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "const": "MXN"
        },
        "volume": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "normalizationProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_raw_snapshot_id", "transformation_notes"],
      "properties": {
        "source_raw_snapshot_id": {
          "type": "string",
          "minLength": 1
        },
        "transformation_notes": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
